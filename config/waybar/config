{
  "layer": "top",
  "position": "top",
  "height": 25,
  "margin-top": 2,
  "margin-left": 8,
  "margin-right": 8,
  "spacing": 0,
 "hide-empty-text": true,
 
  "modules-left": [
    "sway/workspaces",
    "sway/window"
  ],
  "modules-center": [
    "clock#time"
  ],
  "modules-right": [
    "custom/notification",
    "custom/capslock",
    "tray",
    "custom/numlock",
    "pulseaudio",
    "temperature",
    "sway/language",
    "network",
    "custom/power"
  ],

  "sway/workspaces": {
    "all-outputs": true,
    "format": "{name}",
    "persistent_workspaces": {
      "1": [],
      "2": [],
      "3": []
    }
  },

  "sway/window": {
    "format": "{}",
    "max-length": 30
  },
  
 "custom/capslock": {
  "exec": "grep -q 1 /sys/class/leds/*::capslock/brightness 2>/dev/null && echo '󰪛 ' || echo ''",
  "interval": 1
},
"custom/numlock": {
  "exec": "grep -q 1 /sys/class/leds/*::numlock/brightness 2>/dev/null && echo '󰎲 ' || echo ''",
  "interval": 1

},


"pulseaudio": {
    "format": "{volume}% {icon} ",
    "format-muted": "󰝟 Muted",
    "format-icons": {
      "headphone": "",
      "default": ["󰕿", "󰖀", "󰕾"]
    },
    "on-click": "wpctl set-mute @DEFAULT_AUDIO_SINK@ toggle",
    "on-scroll-up": "wpctl set-volume @DEFAULT_AUDIO_SINK@ 5%+",
    "on-scroll-down": "wpctl set-volume @DEFAULT_AUDIO_SINK@ 5%-",
    "tooltip": true,
    "tooltip-format": "{desc} at {volume}%"
  },

"custom/notification": {
    "tooltip": false,
    "format": "{}", 
    "return-type": "json",
    "exec": "~/.config/waybar/notif-status.sh",
    "on-click": "makoctl dismiss -a",
    "on-click-right": "makoctl restore",
    "escape": true
    },
  

"sway/language": {
    "format": "{short} ",
    "format-us": "",
    "format-ara": "",
    "tooltip": false
},


  "tray": {
    "icon-size": 13,
    "spacing": 8
  },
       
"clock#time": {
  "format": "{:%H:%M}",
  "tooltip": false
},

"clock#date": {
  "format": "{:%A %d %B}",
  "tooltip": true,
  "tooltip-format": "<tt><big>{calendar}</big></tt>",
  "actions": {
    "on-scroll-up": "shift_up",
    "on-scroll-down": "shift_down",
    "on-click-right": "mode"
  },
"calendar": {
    "mode": "month",
    "mode-mon-col": 3,
    "on-scroll": 1,
    "format": {
      "months": "<span color='#ffead3'><b>{}</b></span>",
      "days": "<span color='#ecc6d9'><b>{}</b></span>",
      "weekdays": "<span color='#ffcc66'><b>{}</b></span>",
      "today": "<span color='#ff6699'><b><u>{}</u></b></span>"
    }
  }
},


"temperature": {
  "thermal-zone": 7,
  "critical-threshold": 80,
  "format": "{temperatureC}°  ",
  "format-critical": "{temperatureC}  ",
  "interval": 30,
  "tooltip": true,
  "tooltip-format": "CPU Temperature {temperatureC}°C"
},

"network": {
    "interval": 5,
    "format-wifi": "󰖩  {essid}",
    "format-ethernet": "󰈀  {ifname}",
    "format-disconnected": "  offline",
    "format-linked": "󰈀  linked",
    "tooltip-format-wifi": "󰖩  {ipaddr}",
    "tooltip-format-ethernet": "󰈀  {ipaddr}",
    "tooltip-format-disconnected": "disconnected",
    "on-click": "kitty nmtui"
},



"custom/power": {
    "format": "󰿅 " ,
    "tooltip": false,
    "on-click": "~/.config/sway/scripts/power-menu.sh"
  }
}

