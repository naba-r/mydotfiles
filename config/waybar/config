{
  "layer": "top",
  "position": "top",
  "height": 25,
  "margin-top": 2,
  "margin-left": 8,
  "margin-right": 8,
  "spacing": 0,
 "hide-empty-text": true,
 
  "modules-left": [
    "sway/workspaces",
    "sway/window"
  ],
  "modules-center": [
    "clock#time"
  ],
  "modules-right": [
     "custom/notification",
    "clock#date",
    "custom/capslock",
    "tray",
    "custom/numlock",
    "pulseaudio",
    "temperature",
    "sway/language",
    "network",
    "custom/power"
  ],

  "sway/workspaces": {
    "all-outputs": true,
    "format": "{name}",
    "persistent_workspaces": {
      "1": [],
      "2": [],
      "3": []
    }
  },

  "sway/window": {
    "format": "{}",
    "max-length": 30
  },
  
 "custom/capslock": {
  "exec": "grep -q 1 /sys/class/leds/*::capslock/brightness 2>/dev/null && echo 'َ°ھ› ' || echo ''",
  "interval": 1
},
"custom/numlock": {
  "exec": "grep -q 1 /sys/class/leds/*::numlock/brightness 2>/dev/null && echo 'َ°ژ² ' || echo ''",
  "interval": 1

},


  "pulseaudio": {
    "format": "{volume}% {icon} ",
    "format-muted": "َ°‌ں Muted",
    "format-icons": {
      "headphone": "î¹ک",
      "default": ["َ°•؟", "َ°–€", "َ°•¾"]
    },
    "on-click": "wpctl set-mute @DEFAULT_AUDIO_SINK@ toggle",
    "on-scroll-up": "wpctl set-volume @DEFAULT_AUDIO_SINK@ 5%+",
    "on-scroll-down": "wpctl set-volume @DEFAULT_AUDIO_SINK@ 5%-",
    "tooltip": true,
    "tooltip-format": "{desc} at {volume}%"
  },

  "custom/notification": {
    "tooltip": false,
    "format": "{icon}{text}",
    "format-icons": {
      "notification": "َ±‘½ ",
      "none": "",
      "dnd-notification": "ًں”• ",
      "dnd-none": ""
    },
    "return-type": "json",
    "exec-if": "which swaync-client",
    "exec": "swaync-client -swb | jq --unbuffered --compact-output 'if .text == \"0\" then .text = \"\" else . end'",
    "on-click": "swaync-client -t -sw",
    "on-click-right": "swaync-client -d -sw",
    "escape": true
  },

"sway/language": {
    "format": "{short} ",
    "format-us": "ï„œ",
    "format-ara": "ï„œ",
    "tooltip": false
},


  "tray": {
    "icon-size": 13,
    "spacing": 8
  },
       
"clock#time": {
  "format": "{:%H:%M}",
  "tooltip": false
},

"clock#date": {
  "format": "{:%A %d %B}",
  "tooltip": true,
  "tooltip-format": "<tt><big>{calendar}</big></tt>",
  "actions": {
    "on-scroll-up": "shift_up",
    "on-scroll-down": "shift_down",
    "on-click-right": "mode"
  },
"calendar": {
    "mode": "month",
    "mode-mon-col": 3,
    "on-scroll": 1,
    "format": {
      "months": "<span color='#ffead3'><b>{}</b></span>",
      "days": "<span color='#ecc6d9'><b>{}</b></span>",
      "weekdays": "<span color='#ffcc66'><b>{}</b></span>",
      "today": "<span color='#ff6699'><b><u>{}</u></b></span>"
    }
  }
},


"temperature": {
  "thermal-zone": 7,
  "critical-threshold": 80,
  "format": "{temperatureC} َ°”„ ",
  "format-critical": "{temperatureC} î¼ھ ",
  "interval": 30,
  "tooltip": true,
  "tooltip-format": "CPU Package: {temperatureC}آ°C"
},

"network": {
    "interval": 5,
    "format-wifi": "َ°–©  wifi",
    "format-ethernet": "َ°ˆ€  eth",
    "format-disconnected": "ï’­  offline",
    "format-linked": "َ°ˆ€  linked",
    "tooltip": false
},



  "custom/power": {
    "format": "َ°؟… " ,
    "tooltip": false,
    "on-click": "~/.config/sway/scripts/power-menu.sh"
  }
}

